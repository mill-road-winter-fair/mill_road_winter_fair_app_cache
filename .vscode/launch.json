{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run MRWF Caching API",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}",
            "env": {
                "PORT": "8080"
            },
            "args": [
                "-logtostderr=true",
                "-stderrthreshold=INFO"
              ]
        },
        {
            "name": "Debug - Run MRWF Caching API",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}",
            "env": {
                "PORT": "8080"
            },
            "args": [
                "-logtostderr=true",
                "-stderrthreshold=INFO"
              ]
        },
    ]
}